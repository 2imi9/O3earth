# --- AI Chat: pick ONE option ---

# Option 1: NVIDIA NIM cloud API (recommended, no GPU needed)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-20b
NVIDIA_MAX_TOKENS=8192

# Option 2: Local vLLM (requires GPU + pip install vllm)
# VLLM_MODEL=Qwen/Qwen3-8B
# VLLM_DTYPE=float16
# VLLM_GPU_MEMORY=0.9

# --- Optional API keys ---
# Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=
PLANETARY_COMPUTER_KEY=

# Use http://api:8000/api for Docker, http://localhost:8000/api for local dev
API_BASE_URL=http://api:8000/api
